# ── Feekr Code sayti — muhit o'zgaruvchilari ───────────────────────────────
# Bu faylni `.env.local` ga nusxalang va qiymatlarni to'ldiring (deploy'da Vercel/Netlify
# panelidan kiritasiz). `.env.local` git'ga TUSHMAYDI (maxfiy).

# O'yin joylashgan GitHub repo (yuklab olish + auto-update manbai).
# Releases shu repodan o'qiladi: https://github.com/<OWNER>/<REPO>/releases/latest
GITHUB_OWNER=IbnMansooR
GITHUB_REPO=feekrcode

# (ixtiyoriy) GitHub API rate-limitни oshirish uchun token (faqat 'public_repo' o'qish).
# Bo'sh bo'lsa ham ishlaydi, lekin soatiga ~60 so'rovga cheklanadi.
GITHUB_TOKEN=

# (ixtiyoriy) Waitlist (ro'yxatga yozilish) uchun Upstash Redis — BEPUL tarif.
# https://upstash.com → Redis DB yarating → REST URL va TOKEN ni shu yerga qo'ying.
# Bo'sh bo'lsa, ro'yxat vaqtinchalik xotiraга yoziladi (demo rejim).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Saytning to'liq manzili (SEO / og:url uchun)
NEXT_PUBLIC_SITE_URL=https://feekrcode.uz
